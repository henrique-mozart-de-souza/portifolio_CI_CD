pipeline {
    agent any

    environment {
        AWS_REGION       = 'us-east-1'
        // Desliga perguntas interativas do Terraform no terminal
        TF_IN_AUTOMATION = 'true'
        // Define o ambiente alvo
        TF_WORKSPACE     = 'dev' 
    }

    stages {
        stage('1. Checkout da Infraestrutura') {
            steps {
                echo '🧹 Limpando workspace do Jenkins...'
                // Limpa a pasta do Jenkins para não misturar os arquivos do repo CI/CD com os da Infra
                deleteDir() 
                
                echo '📥 Baixando código do repositório portifolio_infra...'
                // Clona o repositório de infraestrutura real para o Terraform trabalhar
                git url: 'https://github.com/henrique-mozart-de-souza/portifolio_infra.git', branch: 'main'
            }
        }

        stage('2. Setup & Init') {
            steps {
                echo '⚙️ Preparando o ambiente Terraform...'
                
                sh 'curl -L https://raw.githubusercontent.com/warrensbox/terraform-switcher/release/install.sh | bash || true'
                sh 'tfswitch'
                
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding', 
                    credentialsId: 'aws-credentials-id', 
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID', 
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    // Inicia o Terraform (Ele já vai ler o TF_WORKSPACE automaticamente)
                    sh 'terraform init'
                }
            }
        }

        stage('3. Lint & Validate') {
            steps {
                echo '🔎 Checando formatação e sintaxe...'
                // Se o código estiver mal identado, a pipeline quebra aqui (Boas práticas!)
                sh 'terraform fmt -check -no-color'
                sh 'terraform validate -no-color'
            }
        }

        stage('4. Plan') {
            steps {
                echo '🗺️ Gerando o plano de execução...'
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding', 
                    credentialsId: 'aws-credentials-id', 
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID', 
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    // Cria um arquivo físico 'tfplan' com as mudanças planejadas
                    sh 'terraform plan -var-file="environments/${TF_WORKSPACE}.tfvars" -out=tfplan -no-color'
                }
            }
        }

        stage('5. Aprovação Manual') {
            steps {
                echo '⏳ Aguardando aprovação humana (Timeout de 30 minutos)...'
                // A pipeline congela aqui. O Jenkins libera a interface para você clicar.
                timeout(time: 30, unit: 'MINUTES') {
                    input message: 'Revise o Terraform Plan no Console Output. Deseja aplicar na AWS?', ok: 'Aprovar e Provisionar'
                }
            }
        }

        stage('6. Apply') {
            steps {
                echo '🚀 Aplicando infraestrutura na AWS...'
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding', 
                    credentialsId: 'aws-credentials-id', 
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID', 
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    // Executa exatamente o que foi aprovado no arquivo 'tfplan'
                    sh 'terraform apply -no-color tfplan'
                }
            }
        }
    }

    post {
        success {
            echo '✅ Infraestrutura provisionada com sucesso! Verifique os Outputs no final do log do Jenkins.'
        }
        aborted {
            echo '⏸️ Pipeline cancelada ou tempo de aprovação esgotado. Nenhuma mudança foi feita na AWS.'
        }
        failure {
            echo '❌ Erro ao provisionar infraestrutura. Verifique os logs.'
        }
    }
}